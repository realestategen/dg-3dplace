*.log
logs/
wandb/

# Temporary files
tmp/
temp/
.cache/

# OS
.DS_Store
Thumbs.db

# Keep directory structure with .gitkeep
!room/output/.gitkeep
!room/data/.gitkeep
!room/data/images/.gitkeep
